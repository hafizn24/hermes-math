        <!-- Formula box -->
        <mxCell id="formula-box" value="Distance Formula:&#10;AB = √[(x₂-x₁)² + (y₂-y₁)²]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;" vertex="1" parent="1">
          <mxGeometry width="200" height="80" x="525" y="50"/>
        </mxCell>
        
        <!-- Calculation steps -->
        <mxCell id="calc-steps" value="Steps:&#10;1. Δx = 1 - (-3) = 4&#10;2. Δy = 4 - (-1) = 5&#10;3. AB = √(4² + 5²) = √41 ≈ 6.4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;" vertex="1" parent="1">
