          <mxGeometry width="60" height="60" x="535" y="110"/>
        </mxCell>
        
        <!-- Distance line -->
        <mxCell id="distance-line" value="AB = √[(1-(-3))² + (4-(-1))²]" style="endArrow=classic;html=1;strokeColor=#f44336;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry width="400" height="20" x="235" y="270"/>
        </mxCell>
        
        <!-- Horizontal component -->
        <mxCell id="horizontal" value="Δx = 4" style="endArrow=classic;html=1;strokeColor=#2196f3;strokeWidth=2;dashed=1;" vertex="1" parent="1">
